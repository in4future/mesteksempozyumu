---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";
import { duzenlemeKurulu } from "../data/siteData";
---

<Layout title="Düzenleme Kurulu">
  <!-- Page Header -->
  <section
    class="bg-gradient-to-br from-[#0B2545] to-[#134074] text-white py-16"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="flex flex-col md:flex-row md:items-center md:justify-between gap-6"
      >
        <div>
          <nav
            class="flex items-center gap-2 text-xs sm:text-sm text-blue-200 mb-3"
            aria-label="Ekmek Kırıntısı"
          >
            <a href="/" class="hover:text-white transition-colors">Ana Sayfa</a>
            <Icon name="chevron-right" class="w-3.5 h-3.5" />
            <span class="text-white">Düzenleme Kurulu</span>
          </nav>
          <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">
            Düzenleme Kurulu
          </h1>
          <p class="mt-2 text-blue-100 text-sm sm:text-base max-w-2xl">
            Sempozyumun organizasyon sürecini yöneten, Gazi Üniversitesi ve
            Teknik Eğitim Vakfı temsilcilerinden oluşan kurul.
          </p>
        </div>
        <div
          class="shrink-0 bg-white/10 p-3 rounded-xl border border-white/20 hidden md:block"
        >
          <Icon name="users" class="w-10 h-10 text-blue-200" />
        </div>
      </div>
    </div>
  </section>

  <!-- Committee List -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
      <!-- Onursal Başkanlar -->
      <div class="space-y-6 flex flex-col items-center text-center">
        <h2
          class="text-xl sm:text-2xl font-bold text-[#0B2545] border-b border-slate-100 pb-3 flex items-center justify-center gap-2.5 w-full"
        >
          <span>Sempozyum Onursal Başkanları</span>
        </h2>
        <div
          class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-4xl w-full justify-center"
        >
          {
            duzenlemeKurulu.onursalBaskanlar.map((president) => (
              <div class="bg-gradient-to-br from-slate-50 to-blue-50/20 border border-slate-100 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col items-center justify-between border-t-4 border-t-[#134074] text-center">
                <div>
                  <h3 class="text-lg font-bold text-[#0B2545]">
                    {president.name}
                  </h3>
                  <p class="text-sm font-medium text-slate-600 mt-1">
                    {president.institution}
                  </p>
                </div>
                <p class="text-xs font-semibold text-[#134074] mt-4 pt-3 border-t border-slate-200/50 uppercase tracking-wider w-full text-center">
                  {president.title}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Düzenleme Kurulu Başkanı -->
      <div class="space-y-6 flex flex-col items-center text-center">
        <h2
          class="text-xl sm:text-2xl font-bold text-[#0B2545] border-b border-slate-100 pb-3 flex items-center justify-center gap-2.5 w-full"
        >
          <span>Düzenleme Kurulu Başkanı</span>
        </h2>
        <div class="flex justify-center max-w-md w-full">
          <div
            class="bg-gradient-to-br from-slate-50 to-blue-50/20 border border-slate-100 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all flex flex-col items-center justify-between border-t-4 border-t-[#0B2545] w-full text-center"
          >
            <div>
              <h3 class="text-lg font-bold text-[#0B2545]">
                {duzenlemeKurulu.baskan.name}
              </h3>
              <p class="text-sm font-medium text-slate-600 mt-1">
                {duzenlemeKurulu.baskan.institution}
              </p>
            </div>
            <p
              class="text-xs font-semibold text-[#0B2545] mt-4 pt-3 border-t border-slate-200/50 uppercase tracking-wider w-full text-center"
            >
              {duzenlemeKurulu.baskan.title}
            </p>
          </div>
        </div>
      </div>

      <!-- Kurul Üyeleri (Committee Members) -->
      <div class="space-y-6">
        <h2
          class="text-xl sm:text-2xl font-bold text-[#0B2545] border-b border-slate-100 pb-3 flex items-center gap-2.5"
        >
          <span class="w-1.5 h-6 bg-[#0B2545] rounded"></span>
          <span>Düzenleme Kurulu Üyeleri</span>
        </h2>
        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4">
            {
              duzenlemeKurulu.uyeler.map((member) => (
                <div class="flex items-start gap-3 py-2 border-b border-slate-200/50 last:border-0">
                  <div class="w-2.5 h-2.5 rounded-full bg-[#134074] mt-2 shrink-0" />
                  <div>
                    <p class="text-sm sm:text-base font-bold text-slate-900">
                      {member.name}
                    </p>
                    <p class="text-xs text-slate-500">{member.title}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Sempozyum Sekreterliği (Secretariat) -->
      <div class="space-y-6">
        <h2
          class="text-xl sm:text-2xl font-bold text-[#0B2545] border-b border-slate-100 pb-3 flex items-center gap-2.5"
        >
          <span class="w-1.5 h-6 bg-[#0B2545] rounded"></span>
          <span>Sempozyum Sekreterliği</span>
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {
            duzenlemeKurulu.sekreterler.map((member) => (
              <div class="bg-slate-50 border border-slate-100 rounded-xl p-6 hover:shadow-sm transition-all flex justify-between items-center gap-4">
                <div>
                  <p class="text-lg font-bold text-slate-900">{member.name}</p>
                  <p class="text-xs text-[#134074] font-semibold mt-1">
                    {member.title}
                  </p>
                </div>
                <span class="px-2.5 py-1 rounded bg-[#0B2545]/10 text-[#0B2545] text-xs font-bold uppercase tracking-wider">
                  Sekreterlik
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
