---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { siteConfig } from '../data/siteData';
---

<Layout title="Tam Metin Gönderimi">
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-[#0B2545] to-[#134074] text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <nav class="flex items-center gap-2 text-xs sm:text-sm text-blue-200 mb-3" aria-label="Ekmek Kırıntısı">
            <a href="/" class="hover:text-white transition-colors">Ana Sayfa</a>
            <Icon name="chevron-right" class="w-3.5 h-3.5" />
            <span class="text-white">Tam Metin Gönderimi</span>
          </nav>
          <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">Tam Metin Gönderimi</h1>
          <p class="mt-2 text-blue-100 text-sm sm:text-base max-w-2xl">
            MESTEK'26 sempozyum bildirilerinizi göndermek için gereken tüm süreçler ve bildiri sistemi yönergeleri.
          </p>
        </div>
        <div class="shrink-0 bg-white/10 p-3 rounded-xl border border-white/20 hidden md:block">
          <Icon name="send" class="w-10 h-10 text-blue-200" />
        </div>
      </div>
    </div>
  </section>

  <!-- Main Info -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Guidelines & Process -->
        <div class="lg:col-span-8 space-y-8">
          
          <div class="space-y-4">
            <h2 class="text-2xl font-bold text-[#0B2545]">Bildiri Değerlendirme ve Gönderim Süreci</h2>
            <p class="text-slate-600 leading-relaxed text-sm sm:text-base">
              Sempozyumumuza gönderilen tüm bildiriler, alanında uzman en az iki hakem tarafından <strong>çift kör hakemlik (double-blind peer review)</strong> sürecine tabi tutulacaktır. Hakem değerlendirmelerinin ardından kabul edilen bildiriler, sunumun gerçekleştirilmesi şartıyla ISBN'li bildiri e-kitabında yer alacaktır.
            </p>
          </div>

          <!-- Process Steps -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            <div class="p-5 bg-slate-50 border border-slate-100 rounded-xl relative group">
              <span class="absolute top-4 right-4 text-xs font-bold text-blue-400">Adım 01</span>
              <div class="p-2 w-fit rounded bg-[#0B2545]/5 text-[#0B2545] mb-4">
                <Icon name="document" class="w-5 h-5" />
              </div>
              <h3 class="font-bold text-sm text-[#0B2545] mb-1">Şablona Göre Hazırlık</h3>
              <p class="text-xs text-slate-500 leading-relaxed">Bildirinizi Yazım Kuralları sayfamızda bulunan şablona tam uyumlu olarak hazırlayınız.</p>
            </div>

            <div class="p-5 bg-slate-50 border border-slate-100 rounded-xl relative group">
              <span class="absolute top-4 right-4 text-xs font-bold text-blue-400">Adım 02</span>
              <div class="p-2 w-fit rounded bg-[#0B2545]/5 text-[#0B2545] mb-4">
                <Icon name="send" class="w-5 h-5" />
              </div>
              <h3 class="font-bold text-sm text-[#0B2545] mb-1">Sisteme Yükleme / İletim</h3>
              <p class="text-xs text-slate-500 leading-relaxed">Çalışmanızı online bildiri sistemi veya e-posta yoluyla son teslim tarihinden önce gönderiniz.</p>
            </div>

            <div class="p-5 bg-slate-50 border border-slate-100 rounded-xl relative group">
              <span class="absolute top-4 right-4 text-xs font-bold text-blue-400">Adım 03</span>
              <div class="p-2 w-fit rounded bg-[#0B2545]/5 text-[#0B2545] mb-4">
                <Icon name="award" class="w-5 h-5" />
              </div>
              <h3 class="font-bold text-sm text-[#0B2545] mb-1">Kabul ve İlan</h3>
              <p class="text-xs text-slate-500 leading-relaxed">Hakem değerlendirmesi tamamlandıktan sonra kabul/red durumu e-posta ile tarafınıza iletilecektir.</p>
            </div>
          </div>

          <!-- Important Rules Accordion/Note -->
          <div class="bg-blue-50 border border-blue-100 rounded-2xl p-6 space-y-4">
            <h3 class="font-bold text-[#0B2545] flex items-center gap-2">
              <Icon name="info" class="w-5 h-5 text-blue-600" />
              <span>Bildiri Gönderiminde Dikkat Edilmesi Gereken Hususlar</span>
            </h3>
            
            <ul class="space-y-3.5 text-xs sm:text-sm text-slate-700 list-disc list-inside leading-relaxed pl-1">
              <li>Değerlendirme sürecinin sağlıklı yürütülmesi için ilk gönderimde yazar isimleri, kurumları veya yazar kimliğini açığa çıkaracak bilgiler <strong>bildiri dosyasından tamamen çıkarılmalıdır</strong>.</li>
              <li>Benzerlik oranı (intihal raporu) kaynakça hariç <strong>%20'yi aşmamalıdır</strong>. Gönderilen tüm bildiriler iThenticate/Turnitin yazılımları ile taranacaktır.</li>
              <li>Bir yazar, en fazla iki farklı bildiri sunumu yapabilir. Sunumu yapılacak her bildiri için en az bir yazarın katılım kaydının yapılmış olması zorunludur.</li>
              <li>Akademik yükselme ve doçentlik kriterleri doğrultusunda, kabul edilen tüm bildiriler ISBN'li sempozyum e-kitabında yer alacaktır.</li>
            </ul>
          </div>

        </div>

        <!-- Sidebar - Submission Portal Cards -->
        <div class="lg:col-span-4 space-y-6">
          <!-- Submission Action Card -->
          <div class="bg-slate-50 border border-slate-100 rounded-2xl p-6 shadow-sm space-y-4">
            <h3 class="font-bold text-[#0B2545]">Bildiri Gönderimi</h3>
            <p class="text-xs text-slate-600 leading-relaxed">
              Tam metinlerinizi göndermek için aşağıdaki e-posta adresine ".docx" (Word) formatında dosyanızı ve varsa intihal raporunuzu iletiniz.
            </p>
            
            <div class="bg-white border border-slate-200 rounded-xl p-4 space-y-2.5">
              <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider block">Gönderim E-Posta Adresi:</span>
              <a href={`mailto:${siteConfig.contact.email}`} class="text-sm font-bold text-[#0B2545] hover:underline flex items-center gap-1.5 break-all">
                <Icon name="mail" class="w-4 h-4 text-blue-500 shrink-0" />
                <span>{siteConfig.contact.email}</span>
              </a>
            </div>

            <div class="space-y-2 text-xs text-slate-500">
              <p class="flex items-center gap-1.5">
                <Icon name="calendar" class="w-3.5 h-3.5 text-slate-400" />
                <span>Son Gönderim: <strong>16 Ekim 2026</strong></span>
              </p>
              <p class="flex items-center gap-1.5">
                <Icon name="document" class="w-3.5 h-3.5 text-slate-400" />
                <span>Format: <strong>Microsoft Word (.docx)</strong></span>
              </p>
            </div>

            <a href={`mailto:${siteConfig.contact.email}?subject=MESTEK26 Bildiri Başvurusu`} class="block w-full text-center bg-[#0B2545] hover:bg-[#134074] text-white text-xs font-bold py-3.5 rounded-xl shadow-md transition-all">
              Başvuru E-Postası Gönder
            </a>
          </div>

          <!-- Writer Guidelines Card link -->
          <div class="bg-gradient-to-br from-[#0B2545] to-[#134074] text-white rounded-2xl p-6 shadow-md space-y-3">
            <h3 class="font-bold">Yazım Şablonunu İndirin</h3>
            <p class="text-xs text-slate-200 leading-relaxed">
              Bildirinizi şablona göre biçimlendirerek yazım kurallarına uygun hale getirmelisiniz. Yazım kuralları ve şablon indirme linkleri için tıklayınız.
            </p>
            <a href="/yazim-kurallari" class="inline-flex items-center gap-1.5 text-xs font-bold text-blue-300 hover:text-white transition-colors pt-1">
              <span>Yazım Kuralları ve Şablonlar</span>
              <Icon name="chevron-right" class="w-4 h-4" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
