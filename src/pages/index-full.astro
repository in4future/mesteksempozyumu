---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { siteConfig, importantDates } from '../data/siteData';
import { Image } from 'astro:assets';
---

<Layout title="Ana Sayfa" showPopup={true}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-[#0B2545] via-[#134074] to-[#1E3A8A] text-white py-20 lg:py-32 overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:24px_24px] pointer-events-none"></div>
    <div class="absolute -right-20 -top-20 w-96 h-96 rounded-full bg-blue-400/20 blur-3xl pointer-events-none"></div>
    <div class="absolute -left-20 -bottom-20 w-96 h-96 rounded-full bg-blue-900/40 blur-3xl pointer-events-none"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Text -->
        <div class="lg:col-span-8 space-y-6 text-center lg:text-left">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 text-xs sm:text-sm font-semibold tracking-wider text-blue-200">
            <Icon name="award" class="w-4 h-4 text-blue-300" />
            <span>GAZİ ÜNİVERSİTESİ & TEKNİK EĞİTİM VAKFI</span>
          </div>
          
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight">
            1. Mesleki ve Teknik Eğitim Sempozyumu
            <span class="block mt-2 text-transparent bg-clip-text bg-gradient-to-r from-blue-200 to-white text-3xl sm:text-4xl lg:text-5xl font-bold font-sans">
              MESTEK'26
            </span>
          </h1>
          
          <p class="text-xl sm:text-2xl font-medium text-slate-200 max-w-3xl italic">
            "{siteConfig.slogan}"
          </p>
          
          <p class="text-base text-slate-300 max-w-2xl leading-relaxed">
            Mesleki ve teknik eğitimin gelişimine katkı sağlamak, eğitim ile endüstri arasındaki iş birliğini güçlendirmek ve bilimsel bilgi paylaşımını artırmak amacıyla düzenlenen çok disiplinli akademik buluşma.
          </p>
          
          <!-- CTA Buttons -->
          <div class="flex flex-wrap gap-4 justify-center lg:justify-start pt-4">
            <a href="/tam-metin-gonderimi" class="inline-flex items-center gap-2 bg-white text-[#0B2545] font-bold px-6 py-3.5 rounded-lg shadow-lg hover:bg-slate-100 active:bg-slate-200 transition-all duration-200 focus:ring-2 focus:ring-white">
              <Icon name="send" class="w-4 h-4" />
              <span>Bildiri Gönder</span>
            </a>
            <a href="/tam-metin-gonderimi" class="inline-flex items-center gap-2 bg-[#134074] text-white border border-blue-400/30 font-semibold px-6 py-3.5 rounded-lg hover:bg-blue-900 active:bg-blue-950 transition-all duration-200 focus:ring-2 focus:ring-blue-400">
              <Icon name="document" class="w-4 h-4" />
              <span>Şablon ve Kurallar</span>
            </a>
          </div>
        </div>

        <!-- Info Card -->
        <div class="lg:col-span-4 bg-white/10 backdrop-blur-md rounded-2xl p-6 border border-white/15 shadow-xl text-left space-y-6">
          <h2 class="text-lg font-bold border-b border-white/20 pb-3 text-white">Sempozyum Bilgileri</h2>
          
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div class="p-2 rounded-lg bg-white/10 text-blue-200 mt-1">
                <Icon name="calendar" class="w-5 h-5" />
              </div>
              <div>
                <p class="text-xs text-slate-300 uppercase font-semibold">Tarih</p>
                <p class="text-sm font-bold text-white">5-6 Kasım 2026</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="p-2 rounded-lg bg-white/10 text-blue-200 mt-1">
                <Icon name="map-pin" class="w-5 h-5" />
              </div>
              <div>
                <p class="text-xs text-slate-300 uppercase font-semibold">Konum / Yer</p>
                <p class="text-sm font-bold text-white">Gazi Üniversitesi, Ankara</p>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="p-2 rounded-lg bg-white/10 text-blue-200 mt-1">
                <Icon name="globe" class="w-5 h-5" />
              </div>
              <div>
                <p class="text-xs text-slate-300 uppercase font-semibold">Katılım Şekli</p>
                <p class="text-sm font-bold text-white">Yüz Yüze ve Çevrimiçi (Online)</p>
              </div>
            </div>
          </div>

          <div class="pt-4 border-t border-white/10 flex justify-between items-center text-xs text-slate-300 font-semibold">
            <span>ISBN'li Bildiri Kitabı</span>
            <span class="px-2 py-0.5 rounded bg-blue-500/20 text-blue-300 border border-blue-400/30">Çift Kör Hakem</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Önemli Tarihler / Takvim Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl font-extrabold text-[#0B2545] tracking-tight">Sempozyum Takvimi</h2>
        <p class="mt-4 text-slate-600 text-lg">
          MESTEK'26 ile ilgili tüm kritik aşamaları ve son teslim tarihlerini aşağıdan inceleyebilirsiniz.
        </p>
      </div>

      <!-- Timeline Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8">
        {importantDates.map((item, index) => (
          <div class="relative bg-slate-50 rounded-2xl p-6 border border-slate-100 hover:border-blue-200 hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between group">
            <div class="space-y-4">
              <!-- Top bar with index and icon -->
              <div class="flex justify-between items-center">
                <span class="text-4xl font-extrabold text-[#0B2545]/10 group-hover:text-[#0B2545]/20 transition-colors">0{index + 1}</span>
                <div class="p-2.5 rounded-xl bg-[#0B2545]/5 text-[#0B2545] group-hover:bg-[#0B2545] group-hover:text-white transition-colors duration-300">
                  <Icon name={item.icon} class="w-5 h-5" />
                </div>
              </div>
              
              <!-- Content -->
              <div class="space-y-2">
                <h3 class="font-bold text-slate-900 leading-snug group-hover:text-[#0B2545] transition-colors">{item.title}</h3>
                <p class="text-xs text-slate-500 leading-relaxed">{item.description}</p>
              </div>
            </div>
            <!-- Date box -->
            <div class="mt-6 pt-4 border-t border-slate-150">
              <span class="text-sm font-extrabold text-[#0B2545] block">{item.date}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Kongreye Çağrı / Davet Mektubu Section -->
  <section class="py-20 bg-slate-50 border-y border-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-12">
        <!-- Main Invitation Text -->
        <div class="bg-white rounded-2xl p-8 sm:p-10 shadow-sm border border-slate-100 space-y-6 w-full">
          <div class="flex items-center gap-3 border-b border-slate-100 pb-5">
            <div class="p-2 rounded-lg bg-[#0B2545] text-white">
              <Icon name="info" class="w-6 h-6" />
            </div>
            <div>
              <h2 class="text-2xl font-bold text-[#0B2545]">KONGREYE ÇAĞRI</h2>
              <p class="text-xs text-slate-500 font-semibold uppercase tracking-wider">1. Mesleki ve Teknik Eğitim Sempozyumu – MESTEK’26</p>
            </div>
          </div>

          <h3 class="text-lg font-bold text-[#134074]">Tema: “Eğitimden Endüstriye Bilginin Yolculuğu”</h3>

          <div class="space-y-4 text-slate-600 leading-relaxed text-sm sm:text-base">
            <p class="font-semibold text-slate-800">Değerli Bilim İnsanları, Araştırmacılar ve Eğitimciler,</p>
            
            <p>
              Gazi Üniversitesi ve Teknik Eğitim Vakfı iş birliğiyle; mesleki ve teknik eğitimin gelişimine katkı sağlamak, eğitim ile endüstri arasındaki iş birliğini güçlendirmek ve bilimsel bilgi paylaşımını artırmak amacıyla düzenlenen çok disiplinli 1. Mesleki ve Teknik Eğitim Sempozyumu’na (MESTEK’26) sizleri davet etmekten büyük mutluluk duymaktayız.
            </p>
            
            <p>
              “Eğitimden Endüstriye Bilginin Yolculuğu” temasıyla gerçekleştirilecek olan sempozyumumuz; akademisyenleri, sektör temsilcilerini, öğretmenleri ve öğrencileri bir araya getirerek disiplinlerarası etkileşimi ve yenilikçi yaklaşımların paylaşımını hedeflemektedir.
            </p>
            
            <p>
              Sempozyumumuz 5-6 Kasım 2026 tarihlerinde Gazi Üniversitesi Ankara/TÜRKİYE’de yüz yüze ve çevrimiçi (online) katılım imkânı ile gerçekleştirilecektir.
            </p>
            
            <p>
              Gönderilen bildiriler, çift kör hakemlik sürecinden geçirilerek değerlendirilecek olup, kabul edilen çalışmalar ISBN’li bildiri kitaplarında yayımlanacaktır. Sempozyumumuz, akademik yükselme kriterlerine uygun bilimsel bir etkinlik olarak planlanmaktadır.
            </p>
            
            <p>
              Mesleki ve teknik eğitimin geleceğine yön verecek değerli çalışmalarınızla sizleri aramızda görmekten onur duyarız.
            </p>
            
            <p>Katılımınızı bekler, saygılar sunarız.</p>
          </div>

          <!-- Signature -->
          <div class="pt-6 border-t border-slate-100 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
              <p class="font-bold text-[#0B2545]">Sempozyum Düzenleme Kurulu</p>
              <p class="text-xs text-slate-500">Gazi Üniversitesi & Teknik Eğitim Vakfı</p>
            </div>
            <div class="text-sm">
              <a href="/duzenleme-kurulu" class="inline-flex items-center gap-1 font-semibold text-[#134074] hover:text-[#0B2545] transition-colors">
                <span>Kurulları Görüntüle</span>
                <Icon name="chevron-right" class="w-4 h-4" />
              </a>
            </div>
          </div>
        </div>

        <!-- Sidebar / Highlight Cards (Placed 2-column side-by-side underneath) -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          
          <!-- Key details card -->
          <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm space-y-6 flex flex-col justify-between">
            <div class="space-y-6">
              <h3 class="font-bold text-[#0B2545] border-b border-slate-100 pb-3">Neden Katılmalısınız?</h3>
              
              <ul class="space-y-5">
                <li class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-lg bg-[#0B2545]/5 text-[#0B2545] flex items-center justify-center shrink-0">
                    <Icon name="award" class="w-5 h-5" />
                  </div>
                  <div>
                    <h4 class="text-sm font-bold text-slate-900">Akademik Teşvik</h4>
                    <p class="text-xs text-slate-500 mt-0.5">Yeni doçentlik ve akademik yükselme kriterlerine uygun bilimsel program.</p>
                  </div>
                </li>

                <li class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-lg bg-[#0B2545]/5 text-[#0B2545] flex items-center justify-center shrink-0">
                    <Icon name="book-open" class="w-5 h-5" />
                  </div>
                  <div>
                    <h4 class="text-sm font-bold text-slate-900">ISBN'li Bildiri Kitabı</h4>
                    <p class="text-xs text-slate-500 mt-0.5">Kabul edilen tam metinler ISBN'li bildiri e-kitaplarında basılacaktır.</p>
                  </div>
                </li>

                <li class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-lg bg-[#0B2545]/5 text-[#0B2545] flex items-center justify-center shrink-0">
                    <Icon name="globe" class="w-5 h-5" />
                  </div>
                  <div>
                    <h4 class="text-sm font-bold text-slate-900">Hibrit Katılım Seçeneği</h4>
                    <p class="text-xs text-slate-500 mt-0.5">Yüz yüze gelme imkanı olmayanlar için online (çevrimiçi) canlı sunum odaları.</p>
                  </div>
                </li>
              </ul>
            </div>
            
            <div class="pt-4 border-t border-slate-100 flex justify-end">
              <a href="/tam-metin-gonderimi" class="inline-flex items-center gap-1.5 text-xs font-bold text-[#134074] hover:text-[#0B2545] transition-colors">
                <span>Tam Metin Gönderimi</span>
                <Icon name="chevron-right" class="w-4 h-4" />
              </a>
            </div>
          </div>

          <!-- Secondary committee box / Quick contact -->
          <div class="bg-gradient-to-br from-[#0B2545] to-[#134074] text-white rounded-2xl p-6 space-y-6 shadow-md flex flex-col justify-between">
            <div class="space-y-4">
              <h3 class="font-bold text-white border-b border-white/10 pb-3">Sorularınız mı Var?</h3>
              <p class="text-xs text-slate-200 leading-relaxed">
                Tam metin gönderimleri, katılım ücretleri veya ulaşım/konaklama ile ilgili tüm sorularınız için sekreterlik ile iletişime geçebilirsiniz.
              </p>
              <div class="space-y-2 pt-2 text-xs">
                <p class="flex items-center gap-2">
                  <Icon name="phone" class="w-4 h-4 text-blue-300" />
                  <span>{siteConfig.contact.phone}</span>
                </p>
                <p class="flex items-center gap-2">
                  <Icon name="mail" class="w-4 h-4 text-blue-300" />
                  <span>{siteConfig.contact.email}</span>
                </p>
              </div>
            </div>
            <div class="pt-4 border-t border-white/10">
              <a href="/iletisim" class="block text-center bg-white text-[#0B2545] text-xs font-bold py-2.5 rounded-lg hover:bg-slate-100 transition-colors">
                İletişim Sayfası
              </a>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Sempozyum Konuları / Scope Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl font-extrabold text-[#0B2545] tracking-tight">Sempozyum Kapsamı ve Konuları</h2>
        <p class="mt-4 text-slate-600 text-lg">
          Disiplinlerarası etkileşimi artırmak amacıyla sempozyumumuz aşağıdaki ana ve alt temalarda bildirileri kabul etmektedir.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Topic 1 -->
        <div class="p-6 bg-slate-50 border border-slate-100 rounded-xl space-y-3 hover:border-blue-200 transition-all">
          <div class="p-2 w-fit rounded bg-blue-100 text-[#0B2545]">
            <Icon name="award" class="w-6 h-6" />
          </div>
          <h3 class="font-bold text-[#0B2545]">Mesleki ve Teknik Eğitim</h3>
          <p class="text-xs text-slate-600 leading-relaxed">
            Mesleki ve teknik eğitim politikaları, istihdam ilişkisi, eğitim yöntemleri, dijitalleşme ve yenilikçi yaklaşımlar.
          </p>
        </div>

        <!-- Topic 2 -->
        <div class="p-6 bg-slate-50 border border-slate-100 rounded-xl space-y-3 hover:border-blue-200 transition-all">
          <div class="p-2 w-fit rounded bg-blue-100 text-[#0B2545]">
            <Icon name="book-open" class="w-6 h-6" />
          </div>
          <h3 class="font-bold text-[#0B2545]">Eğitim Bilimleri</h3>
          <p class="text-xs text-slate-600 leading-relaxed">
            Öğretim teknolojileri, ölçme ve değerlendirme, rehberlik, müfredat ve program geliştirme ile öğretmen eğitimi.
          </p>
        </div>

        <!-- Topic 3 -->
        <div class="p-6 bg-slate-50 border border-slate-100 rounded-xl space-y-3 hover:border-blue-200 transition-all">
          <div class="p-2 w-fit rounded bg-blue-100 text-[#0B2545]">
            <Icon name="users" class="w-6 h-6" />
          </div>
          <h3 class="font-bold text-[#0B2545]">Sosyal Bilimleri</h3>
          <p class="text-xs text-slate-600 leading-relaxed">
            Tarih, coğrafya, sosyoloji, psikoloji, iktisadi ve idari bilimler ile disiplinlerarası sosyal araştırmalar.
          </p>
        </div>

        <!-- Topic 4 -->
        <div class="p-6 bg-slate-50 border border-slate-100 rounded-xl space-y-3 hover:border-blue-200 transition-all">
          <div class="p-2 w-fit rounded bg-blue-100 text-[#0B2545]">
            <Icon name="globe" class="w-6 h-6" />
          </div>
          <h3 class="font-bold text-[#0B2545]">Fen Bilimleri</h3>
          <p class="text-xs text-slate-600 leading-relaxed">
            Fizik, kimya, biyoloji, matematik, mühendislik teknolojileri, bilişim ve yapay zeka uygulamaları.
          </p>
        </div>
      </div>
    </div>
  </section>

</Layout>
